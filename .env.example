# Copy this file to .env and fill in the value.
# .env is gitignored and must NEVER be committed.
#
# ANTHROPIC_API_KEY: server-side key used by src/claude_client.py to call the
# Anthropic Messages API. Obtain one at https://console.anthropic.com/ ->
# Settings -> API Keys. The key has the form "sk-ant-...".
# This project pins the model claude-sonnet-4-20250514 (see PLAN.md S7.1);
# ensure the key has access to that model.
ANTHROPIC_API_KEY=
